generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum HoldingRiskLevel {
  LOW
  HIGH
}

model PortfolioHolding {
  symbol               String            @id
  name                 String
  alias                String?           @db.VarChar(80)
  marketCountry        String
  currency             String
  quantity             Float
  lastPrice            Float
  averagePurchasePrice Float?
  purchaseExchangeRate Float?
  profitLossRate       Float?
  riskLevel            HoldingRiskLevel? @map("risk_level")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@map("tb_portfolio_holdings")
}

model PortfolioDailySnapshot {
  snapshotDate             String    @id @db.VarChar(10)
  totalMarketValueKrw      Float
  exchangeRate             Float
  costBasisKrw             Float?
  annualDividendKrw        Float?
  closeTotalMarketValueKrw Float?
  closeExchangeRate        Float?
  closeCostBasisKrw        Float?
  closeAnnualDividendKrw   Float?
  closedAt                 DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([updatedAt])
  @@index([snapshotDate, closedAt])
  @@map("tb_portfolio_daily_snapshots")
}

model DividendRecord {
  symbol                 String   @id
  currency               String
  annualDividendPerShare Float
  trailingYield          Float?
  expectedPaymentMonths  String   @db.VarChar(80)
  lastDividendPerShare   Float?
  memo                   String?  @db.VarChar(500)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("tb_dividend_records")
}

model MonthlyDividendRecord {
  dividendMonth           String   @id @map("dividend_month") @db.VarChar(7)
  recordId                String   @unique(map: "uq_monthly_dividend_records_record_id") @map("record_id") @db.VarChar(36)
  actualDividendKrw       Int      @map("actual_dividend_krw")
  referenceMarketValueKrw Float?   @map("reference_market_value_krw")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@index([updatedAt], map: "idx_monthly_dividend_records_updated_at")
  @@map("tb_monthly_dividend_records")
}

model Disclosure {
  id            String            @id @default(cuid())
  title         String            @db.VarChar(160)
  body          String            @db.Text
  trades        DisclosureTrade[]
  roadmapEvents RoadmapEvent[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([createdAt])
  @@map("tb_disclosures")
}

model RoadmapEvent {
  id           String     @id @default(cuid())
  disclosureId String     @map("disclosure_id")
  disclosure   Disclosure @relation(fields: [disclosureId], references: [id], onDelete: Cascade)
  eventDate    String     @map("event_date") @db.VarChar(10)
  kind         String     @default("PLANNED") @db.VarChar(20)
  category     String     @default("OTHER") @db.VarChar(24)
  label        String?    @db.VarChar(160)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([disclosureId, eventDate], map: "uq_roadmap_events_disclosure_date")
  @@index([eventDate], map: "idx_roadmap_events_event_date")
  @@index([disclosureId], map: "idx_roadmap_events_disclosure_id")
  @@map("tb_roadmap_events")
}

model DisclosureTrade {
  id            String     @id @default(cuid())
  disclosureId  String
  disclosure    Disclosure @relation(fields: [disclosureId], references: [id], onDelete: Cascade)
  side          String
  symbol        String     @db.VarChar(20)
  name          String
  alias         String?    @db.VarChar(80)
  marketCountry String
  currency      String
  quantity      Float
  orderPrice    Float
  exchangeRate  Float?
  profitRate    Float
  feeKrw        Int        @default(0)
  taxKrw        Int        @default(0)
  orderedAt     DateTime
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([disclosureId])
  @@index([symbol])
  @@map("tb_disclosure_trades")
}

model InvestmentIntent {
  id                     String    @id @default(cuid())
  userId                 String
  userName               String
  userEmail              String
  amountKrw              Int
  depositorName          String
  contact                String
  guardianConfirmed      Boolean   @default(false)
  dividendPolicyAgreed   Boolean   @default(false)
  productDocumentVersion String?   @map("product_document_version") @db.VarChar(32)
  productDocumentHash    String?   @map("product_document_hash") @db.Char(64)
  dividendPolicyVersion  String?   @map("dividend_policy_version") @db.VarChar(32)
  dividendPolicyHash     String?   @map("dividend_policy_hash") @db.Char(64)
  agreedAt               DateTime? @map("agreed_at")
  status                 String    @default("PENDING")
  note                   String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@map("tb_investment_intents")
}

model WithdrawalIntent {
  id                     String    @id @default(cuid())
  userId                 String
  userName               String
  userEmail              String
  amountKrw              Int
  bankName               String
  accountNumber          String    @db.VarChar(255)
  accountHolder          String
  contact                String
  productDocumentVersion String?   @map("product_document_version") @db.VarChar(32)
  productDocumentHash    String?   @map("product_document_hash") @db.Char(64)
  agreedAt               DateTime? @map("agreed_at")
  status                 String    @default("PENDING")
  note                   String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@map("tb_withdrawal_intents")
}

model PortfolioTradeExecution {
  id             String   @id @default(cuid())
  symbol         String   @db.VarChar(20)
  side           String   @db.VarChar(8)
  currency       String   @db.VarChar(3)
  quantity       Float
  orderPrice     Float    @map("order_price")
  exchangeRate   Float?   @map("exchange_rate")
  grossAmountKrw Int      @map("gross_amount_krw")
  feeKrw         Int      @default(0) @map("fee_krw")
  taxKrw         Int      @default(0) @map("tax_krw")
  cashAmountKrw  Int      @map("cash_amount_krw")
  executedAt     DateTime @map("executed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([symbol, executedAt], map: "idx_trade_executions_symbol_time")
  @@index([executedAt], map: "idx_trade_executions_time")
  @@map("tb_portfolio_trade_executions")
}
