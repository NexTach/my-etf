{
  "name": "nxdi-client",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx --test 'src/**/*.test.ts' 'src/**/*.test.tsx'",
    "test:coverage": "node --import tsx --test --experimental-test-coverage 'src/**/*.test.ts' 'src/**/*.test.tsx'",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run test:unit"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.19"
  }
}
